# System
INSTANCE_ID=brain-instance-001
DEPLOYMENT_NAME=dev
ENVIRONMENT=development

# Database
DATABASE_PATH=./workspace/db/brain.db
DATABASE_BUSY_TIMEOUT=30
DATABASE_JOURNAL_MODE=WAL
DATABASE_FOREIGN_KEYS=true

# Workspace
WORKSPACE_ROOT=./workspace
WORKSPACE_CONFIG_DIR=config
WORKSPACE_DB_DIR=db
WORKSPACE_MISSIONS_DIR=missions
WORKSPACE_LOGS_DIR=logs
WORKSPACE_TMP_DIR=tmp

# Logging
LOG_LEVEL=INFO
LOG_FILE=./workspace/logs/brain.log
LOG_STRUCTURED=false

# Recovery
RECOVERY_AUTO_RECOVER=true
RECOVERY_RECOVERABLE_PHASES=EXECUTE,VALIDATE,REPAIR,WAITING_FOR_APPROVAL
RECOVERY_ORPHAN_DETECTION_GRACE_PERIOD_SECONDS=300

# Concurrency
CONCURRENCY_MAX_ACTIVE_MISSIONS=10
CONCURRENCY_HEARTBEAT_INTERVAL_SECONDS=30

# Mission Defaults
MISSION_DEFAULTS_PRIORITY=MEDIUM
MISSION_DEFAULTS_RISK_LEVEL=LOW
MISSION_DEFAULTS_MAX_LOOP_ITERATIONS=10